import Cocoa
let CALORIA_DORMIR = 1.08
let CALORIA_REPOSO = 1.66
var actividad = "Correr"
var tiempo = 180
actividad = actividad.lowercased()
if actividad != "dormir" && actividad != "reposo" {
    print("Error: Actividad inválida. Solo se permite 'dormir' o 'reposo'.")
} else if tiempo <= 0 {
    print("Error: El tiempo debe ser un número entero positivo.")
} else {
    var calorias = 0.0
    
    if actividad == "dormir" {
        calorias = Double(tiempo) * CALORIA_DORMIR
    } else {
        calorias = Double(tiempo) * CALORIA_REPOSO
    }
    
    print("Actividad: \(actividad.uppercased())")
    print("Tiempo: \(tiempo) minutos")
    print("Calorías consumidas: \(calorias)")
